# ══════════════════════════════════════════════════════════════
# TeeTimeQuest — Environment Variables
# Version: 2026.1.1
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in your values below
#   3. Never commit .env.local to Git (it's in .gitignore)
#
# NAMING RULES:
#   VITE_   prefix → accessible in the browser (public, safe for keys with domain restrictions)
#   No prefix      → server-side only (Vercel functions) — NEVER put these in VITE_ vars
# ══════════════════════════════════════════════════════════════


# ── BREVO — Email invites ────────────────────────────────────
# Status: ACTIVE (2026.1.1)
# Get your key: https://app.brevo.com → Account → SMTP & API → API Keys
# ⚠️  Server-side only — no VITE_ prefix
BREVO_API_KEY=your_brevo_api_key_here

# The email address you verified as a sender in Brevo
# (Brevo → Senders & IPs → Senders → Add a sender)
BREVO_SENDER_EMAIL=noreply@teetimequest.com


# ── GOLFNOW — Live tee times ─────────────────────────────────
# Status: Partner approval pending
# Apply at: https://partners.golfnow.com
# ⚠️  Server-side only — no VITE_ prefix
GOLFNOW_API_KEY=your_golfnow_api_key_here


# ── SUPABASE — Database ─────────────────────────────────────
# Status: ACTIVE (2026.2.0)
# Find these at: Supabase Dashboard → Settings → API
# VITE_ prefix = safe for browser (anon key only — not service_role)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# ── GOOGLE PLACES — Richer course data (optional) ────────────
# Status: Optional enhancement
# Enable at: https://console.cloud.google.com → Places API
VITE_GOOGLE_PLACES_KEY=your_google_places_key_here


# ── MAPBOX — Geocoding / triangulation (optional) ────────────
# Status: Optional enhancement (Nominatim handles this for free right now)
# Get a token: https://account.mapbox.com
VITE_MAPBOX_TOKEN=your_mapbox_token_here


# ── APP CONFIG ───────────────────────────────────────────────
# The public URL of your app (no trailing slash)
# Local dev:   http://localhost:3000
# Production:  https://teetimequest.com
VITE_APP_URL=http://localhost:3000

# ── SUPABASE SERVICE ROLE — Cleanup cron job only ────────────
# ⚠️  SERVER-SIDE ONLY. Never prefix with VITE_. Never commit.
# Find at: Supabase Dashboard → Settings → API → service_role key
# Only needed for the /api/cleanup.js cron job.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── CRON SECRET — Protects /api/cleanup from public access ───
# Set to any random string (e.g. openssl rand -hex 32)
# Must match the Authorization: Bearer <secret> header
CRON_SECRET=your_random_secret_here
